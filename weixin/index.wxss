.container {
  padding: 40rpx;
}
.input-group {
  margin-bottom: 40rpx;
}
.label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}
.input {
  border: 1px solid #ddd;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
}
.login-btn, .api-btn {
  margin-top: 20rpx;
}
.status {
  margin-top: 30rpx;
  padding: 20rpx;
  background-color: #f0f9ff;
  border-radius: 8rpx;
  text-align: center;
}
.status-text {
  font-size: 28rpx;
  color: #333;
}
.result {
  margin-top: 20rpx;
  background: #f5f5f5;
  padding: 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  word-break: break-all;
}